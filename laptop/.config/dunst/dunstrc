[global]
    monitor = 0
    follow = mouse
    width = 320
    height = 300
    origin = top-right
    offset = 10x50
    scale = 0
    notification_limit = 20
    progress_bar = true
    progress_bar_height = 6
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    corner_radius = 8
    ignore_newline = false
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = true
    indicate_hidden = yes
    shrink = no
    separation_height = 6
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 0
    frame_width = 2
    frame_color = "#cba6f7"
    gap_size = 0
    sort = yes
    idle_threshold = 120
    font = "JetBrainsMono Nerd Font 10"
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = false
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    icon_path = /usr/share/icons/Adwaita/16x16/status/:/usr/share/icons/Adwaita/32x32/status/
    sticky_history = yes
    history_length = 20
    dmenu = /usr/bin/fuzzel --dmenu
    browser = /usr/bin/xdg-open
    always_run_script = true
    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 5
    frame_color = "#585b70"

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 8
    frame_color = "#cba6f7"

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f38ba8"
    timeout = 0
    frame_color = "#f38ba8"
